# Skladová evidence — příklad konfigurace.
# Zkopíruj na `.env` a uprav. Všechny proměnné jsou volitelné — bez nich appka běží.

# Síť a data
# PORT=3000
# DATA_DIR=/var/lib/sklad           # složka s databází a zálohami (backups/)
# TRUST_PROXY=1                     # za reverzní proxy (Caddy/nginx) → správné IP + Secure cookie

# HTTPS přímo (jinak řeš proxy)
# TLS_KEY=/etc/sklad/key.pem
# TLS_CERT=/etc/sklad/cert.pem

# Automatické zálohy
# BACKUP_INTERVAL_HOURS=24          # 0 = vypnout
# BACKUP_KEEP=14                    # kolik posledních záloh ponechat

# Dohledávání názvů zboží podle kódu
# DISABLE_LOOKUP=1                  # úplně vypnout (offline provoz)
# LOOKUP_TIMEOUT_MS=4000
# GOOGLE_BOOKS_KEY=                 # spolehlivější ISBN (knihy)

# Volitelný placený katalog (nejvyšší priorita)
# BARCODE_API_URL=https://api.poskytovatel.tld/v3/lookup?ean={code}
# BARCODE_API_KEY=                  # → Authorization: Bearer <key>
# BARCODE_API_HEADERS={"x-api-key":"…"}
# BARCODE_API_MAP={"name":"product.title","image":"product.images.0"}
# BARCODE_API_NAME=Můj katalog      # jak se zdroj zobrazí u položky
